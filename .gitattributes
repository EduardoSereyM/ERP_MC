# Normalizar line endings a LF en el repo (CRLF en checkout Windows)
* text=auto eol=lf

# Forzar LF para scripts y código
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.toml  text eol=lf
*.sh    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Binarios — sin conversión
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
